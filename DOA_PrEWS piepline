%  plotMode = 2 => plot all patients in final fold only
%  plotMode = 3 => plot only the patients in 'selectedPatients' )
plotMode = 0;  

% If plotMode=3, specify which patients to plot (for final fold)
selectedPatients = [3617, 5604, 1634, 5925];  % example IDs

%% 1. Paths, Parameters, Setup
addpath('C:\Research project Backup 05072025\Research Project\VitalDB_Data_V6\Extracted_Feaetures_2');
rng(0); % For reproducibility

%% Core parameters
window_duration   = 30;   
num_features      = 10;   % # features per band
num_bands         = 30;   % total bands => 300 columns
k                 = 5;    % folds for cross-validation
max_windows       = 15;   % +/- around target
target_type       = 'LoC';% 'RoC' or 'LoC'
target_offset     = 0;    % used for LoC/RoC prediction offset 
