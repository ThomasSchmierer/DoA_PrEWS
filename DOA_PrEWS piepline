% Data location
results_file = 'C:\Research project Backup 05072025\Research Project\VitalDB_Data_V6\Extracted_Feaetures_2\30\results_3.mat';
if ~isfile(results_file)
    error("Results file not found: %s", results_file);
end
load(results_file, 'results'); 

%% Rescaling results times
scaling_factor = 30 / window_duration;  
temp_results = results;  
temp_results.StartTime   = round(results.StartTime   * scaling_factor);
temp_results.EndTime     = round(results.EndTime     * scaling_factor);
temp_results.FirstBelow60= round(results.FirstBelow60* scaling_factor);
temp_results.LastBelow60 = round(results.LastBelow60 * scaling_factor);
results = temp_results;

%% 2. Load Data (EEG only)
all_data = [];

for i = 1:height(results)
    patient_id  = results.FileNumber(i);
    start_time  = results.StartTime(i);
    end_time    = results.EndTime(i);

    if strcmpi(target_type, 'LoC')
        target_time = results.FirstBelow60(i);
    else
        target_time = results.LastBelow60(i);
    end

    firstBelow = results.FirstBelow60(i);
    lastBelow  = results.LastBelow60(i);

    if isnan(target_time) || isnan(firstBelow) || isnan(lastBelow)
        warning('Patient %d missing target_time or first/lastBelow60 => skipping.', patient_id);
        continue;
    end

    adjusted_target_time = target_time - target_offset;

    patient_file = "C:\Research project Backup 05072025\Research Project\VitalDB_Data_V6\Extracted_Feaetures_2\" + ...
                   window_duration + "\VDB_Gold_Features_Patient_" + ...
                   patient_id + "_Window_" + window_duration + "s.mat";

    if ~isfile(patient_file)
        warning("Patient data file not found: %s. Skipping.", patient_file);
        continue;
    end
    
    try
        load(patient_file, 'feature_data');
    catch ME
        warning("Error loading file: %s. Error: %s. Skipping.", patient_file, ME.message);
        continue;
    end
    
    if isempty(feature_data)
        warning("No valid feature_data in: %s. Skipping.", patient_file);
        continue;
    end

    for j = 1:length(feature_data)
        wtime = feature_data(j).Window;
        if wtime >= start_time && wtime <= end_time
            feature_data(j).Patient_ID     = patient_id;
            feature_data(j).time_to_target = wtime - adjusted_target_time;
            if abs(wtime - adjusted_target_time) < eps
                feature_data(j).state = '1';
            else
                feature_data(j).state = '0';
            end

            if wtime < firstBelow
                feature_data(j).region_label = "Awake";
            elseif wtime <= lastBelow
                feature_data(j).region_label = "Unconscious";
            else
                feature_data(j).region_label = "Recovering";
            end

            all_data = [all_data; feature_data(j)]; %#ok<AGROW>
        end
    end
end

if isempty(all_data)
    error('No valid data loaded. Possibly all patients missing times or no windows in [start,end].');
end

disp('Data loaded successfully. region_label assigned (Awake/Unconscious/Recovering).');

%% 3. Flatten Data
num_data       = length(all_data);
total_EEG_feats= num_features * num_bands;  % e.g., 300
X_all          = zeros(num_data, total_EEG_feats);
BIS_targets    = zeros(num_data, 1);
