    save(saveFileName, 'finalBISfeatures', 'finalTTTfeatures', 'finalClassFeatures');
    fprintf('Computed features saved to %s.\n', saveFileName);
end

%% 5.1. Hyperparameter optimisation with saving for BIS GPR
useSavedHyper = 1;

if useSavedHyper == 1
    loadFileName = ...
      "C:\Research project Backup 05072025\Research Project\All_features\LoC_Prediction\LoCV2\parameters\Hyperparameters\saved_hyper_parameters_LoC_params_30s_window.mat";
    if exist(loadFileName, 'file')
        load(loadFileName, 'bestBISParams');
