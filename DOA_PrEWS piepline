        'HyperparameterOptimizationOptions', struct( ...
            'AcquisitionFunctionName', 'expected-improvement-plus', ...
            'MaxObjectiveEvaluations', 20, ...
            'UseParallel', true, ...
            'ShowPlots', false, ...
            'Verbose', 1));
    bestBISParams = bestBISModel.ModelParameters;
    disp(bestBISParams);
  
    saveFileName = ...
      "C:\Research project Backup 05072025\Research Project\All_features\LoC_Prediction\LoCV2\parameters\Hyperparameters\saved_hyper_parameters_" + ...
      target_type + "_params_" + window_duration + "s_window.mat";
    save(saveFileName, 'bestBISParams');
    fprintf('Saved BIS hyperparameters to %s.\n', saveFileName);
end

%% 6. Cross-Validation
patientIDs = unique([all_data.Patient_ID]);
numPatients= length(patientIDs);
indices    = crossvalind('Kfold', patientIDs, k);

% For BIS regression metrics
correlation_BIS_metrics = [];

% For region classification
region_confMat_sum = zeros(3,3);
region_metrics_all = zeros(k,4);

% For future BIS
correlation_futureBIS = [];

% For TTT model
correlation_metrics = [];

% For classification (transition)
rfMetrics = [];
clf2_confMat_sum = zeros(2,2);

%%% NEW %%% - Cell arrays to store *each fold*'s data and predictions
allFolds_testSet          = cell(k,1);
allFolds_predictedBIS     = cell(k,1);
allFolds_finalProbs       = cell(k,1);  % classification probabilities
allFolds_ensemble_models  = cell(k,1);

allFolds_futureTestSet    = cell(k,1);
allFolds_futurePredBIS    = cell(k,1);
allFolds_futureLower      = cell(k,1);
allFolds_futureUpper      = cell(k,1);

% === NEW for interpretability (future BIS ARD) ===
ARD_future_X = [];
ARD_future_y = [];
histFeatureNames = {};

for fold = 1:k
    % Partition
    testPatients  = patientIDs(indices == fold);
    trainPatients = patientIDs(indices ~= fold);

    trainSet = all_data(ismember([all_data.Patient_ID], trainPatients));
    testSet  = all_data(ismember([all_data.Patient_ID], testPatients));

    [Xtrain_BIS, BIStrain, ~, ~] = prepareData(trainSet, num_features, num_bands);
    [Xtest_BIS,  BIStest,  ~, ~] = prepareData(testSet,  num_features, num_bands);

    [Xtrain_TTT, ~, TTTtrain, StateTrain] = prepareData(trainSet, num_features, num_bands);
    [Xtest_TTT,  ~, TTTtest,  StateTest]  = prepareData(testSet,  num_features, num_bands);

    %% 6A) BIS GPR
    BISmodel_fold = fitrgp( ...
        Xtrain_BIS(:, finalBISfeatures), ...
        BIStrain, ...
        'KernelFunction','matern52', ...
        'BasisFunction', bestBISParams.BasisFunction, ...
        'Sigma',         bestBISParams.Sigma, ...
        'Standardize',   true);

    predictedBIS_train = predict(BISmodel_fold, Xtrain_BIS(:, finalBISfeatures));
    predictedBIS_test  = predict(BISmodel_fold, Xtest_BIS(:, finalBISfeatures));

    mae_BIS  = mean(abs(predictedBIS_test - BIStest));
    rmse_BIS = sqrt(mean((predictedBIS_test - BIStest).^2));

    corr_BIS_train = corr(predictedBIS_train, BIStrain);
    corr_BIS_test  = corr(predictedBIS_test,  BIStest);

    correlation_BIS_metrics = [correlation_BIS_metrics; ...
                               corr_BIS_train, corr_BIS_test, rmse_BIS, mae_BIS];
    fprintf('Fold %d BIS => MAE=%.2f, RMSE=%.2f, CorrTrain=%.2f, CorrTest=%.2f\n',...
            fold, mae_BIS, rmse_BIS, corr_BIS_train, corr_BIS_test);

    % Bland-Altman plot (difference vs mean) for BIS (test)
    mean_BIS = mean([predictedBIS_test, BIStest], 2);
    diff_BIS = predictedBIS_test - BIStest;

    bias = mean(diff_BIS);
    sd_diff = std(diff_BIS);
    loa_upper = bias + 1.96 * sd_diff;
    loa_lower = bias - 1.96 * sd_diff;

    figure;
    scatter(mean_BIS, diff_BIS, 25, 'filled', 'MarkerFaceAlpha', 0.6);
    hold on;
    yline(bias, 'k--', 'LineWidth', 1.5, 'Label', 'Mean Bias');
    yline(loa_upper, 'r--', 'LineWidth', 1.5, 'Label', '+1.96 SD');
    yline(loa_lower, 'r--', 'LineWidth', 1.5, 'Label', '-1.96 SD');

    xlabel('Mean of Predicted and Actual BIS');
    ylabel('Difference (Predicted - Actual)');
    title('Bland-Altman Plot of BIS Prediction');
    grid on;
    hold off;


    %% New Feature Generation (historical predicted BIS)
    trainSet_sorted = sortrows(struct2table(trainSet), {'Patient_ID','Window'});
    testSet_sorted  = sortrows(struct2table(testSet),  {'Patient_ID','Window'});

    trainSet_sorted = table2struct(trainSet_sorted);
    testSet_sorted  = table2struct(testSet_sorted);

    [~, idxTrainMap] = sort([trainSet.Patient_ID]*1e8 + [trainSet.Window]); 
    predBIS_train_sorted = predictedBIS_train(idxTrainMap);

    [~, idxTestMap] = sort([testSet.Patient_ID]*1e8 + [testSet.Window]);
    predBIS_test_sorted = predictedBIS_test(idxTestMap);

    [featHistTrain, newFeatureNamesTrain] = ...
        createHistoricPredBISFeatures(trainSet_sorted, predBIS_train_sorted, window_duration);
    [featHistTest,  newFeatureNamesTest]  = ...
        createHistoricPredBISFeatures(testSet_sorted,  predBIS_test_sorted,  window_duration);

    % record history feature names once
    if fold == 1
        histFeatureNames = newFeatureNamesTrain;
    end

    nFeatRowsTrain = size(featHistTrain, 1);
    validTrain     = idxTrainMap <= nFeatRowsTrain;
    inverseIdxTrainMap = zeros(size(idxTrainMap));
    inverseIdxTrainMap(validTrain) = 1:sum(validTrain);
    featHistTrain_unsorted = featHistTrain(inverseIdxTrainMap(validTrain), :);

    nFeatRowsTest = size(featHistTest, 1);
    validTest     = idxTestMap <= nFeatRowsTest;
    inverseIdxTestMap = zeros(size(idxTestMap));
    inverseIdxTestMap(validTest) = 1:sum(validTest);
    featHistTest_unsorted = featHistTest(inverseIdxTestMap(validTest), :);

    Xtrain_BIS = Xtrain_BIS(validTrain, :);
    Xtest_BIS  = Xtest_BIS(validTest, :);

    Xtrain_BIS = [Xtrain_BIS, featHistTrain_unsorted];
    Xtest_BIS  = [Xtest_BIS,  featHistTest_unsorted];

    %% 6A.2) Region Classification
    Ytrain_region_str = strings(length(trainSet),1);
    for iR = 1:length(trainSet)
        Ytrain_region_str(iR) = trainSet(iR).region_label;
    end
    Ytrain_region_num = regionStr2Num(Ytrain_region_str);

    Ytest_region_str = strings(length(testSet),1);
    for iR = 1:length(testSet)
        Ytest_region_str(iR) = testSet(iR).region_label;
    end
    Ytest_region_num = regionStr2Num(Ytest_region_str);

    idx_c1 = find(Ytrain_region_num == 1);
    idx_c2 = find(Ytrain_region_num == 2);
    idx_c3 = find(Ytrain_region_num == 3);
    count1 = length(idx_c1);
    count2 = length(idx_c2);
    count3 = length(idx_c3);
    maxCount = max([count1, count2, count3]);

    Xtrain_region = Xtrain_BIS;
    Xc1 = Xtrain_region(idx_c1,:);
    short1 = maxCount - count1;
    if short1 > 0
        syn1 = smote(Xc1, short1, k_neighbors);
        Xc1_aug = [Xc1; syn1];
        Yc1_aug = [repmat(1, size(Xc1,1),1); repmat(1, size(syn1,1),1)];
    else
        Xc1_aug = Xc1;
        Yc1_aug = repmat(1, count1,1);
    end

    Xc2 = Xtrain_region(idx_c2,:);
    short2 = maxCount - count2;
    if short2 > 0
        syn2 = smote(Xc2, short2, k_neighbors);
        Xc2_aug = [Xc2; syn2];
        Yc2_aug = [repmat(2, size(Xc2,1),1); repmat(2, size(syn2,1),1)];
    else
        Xc2_aug = Xc2;
        Yc2_aug = repmat(2, count2,1);
    end

    Xc3 = Xtrain_region(idx_c3,:);
    short3 = maxCount - count3;
    if short3 > 0
        syn3 = smote(Xc3, short3, k_neighbors);
        Xc3_aug = [Xc3; syn3];
        Yc3_aug = [repmat(3, size(Xc3,1),1); repmat(3, size(syn3,1),1)];
    else
        Xc3_aug = Xc3;
        Yc3_aug = repmat(3, count3,1);
    end

    X_smote_train = [Xc1_aug; Xc2_aug; Xc3_aug];
    Y_smote_train = [Yc1_aug; Yc2_aug; Yc3_aug];
    idx_sh = randperm(size(X_smote_train,1));
    X_smote_train = X_smote_train(idx_sh,:);
    Y_smote_train = Y_smote_train(idx_sh);
    Y_smote_cat   = categorical(Y_smote_train, [1,2,3], {'Awake','Unconscious','Recovering'});

    extraFeatureIdx = (301:312)';  
    ClassificationBISfeatures = [finalBISfeatures; extraFeatureIdx];

    regionModel = fitcensemble(X_smote_train(:, ClassificationBISfeatures), ...
                               Y_smote_cat, 'Method','Bag', ...
                               'NumLearningCycles',100);
    Xtest_region = Xtest_BIS;
    Ytest_region_cat = categorical(Ytest_region_num, [1,2,3], ...
                                   {'Awake','Unconscious','Recovering'});
    pred_region = predict(regionModel, Xtest_region(:, ClassificationBISfeatures));
    confMat_region = confusionmat(Ytest_region_cat, pred_region, ...
                                  'Order',{'Awake','Unconscious','Recovering'});
    disp('Confusion Matrix (Region Classification):');
    disp(confMat_region);
    fold_regionF1 = computeMultiClassF1(confMat_region);
    fprintf('Fold %d => Region Macro-F1=%.2f%%\n', fold, fold_regionF1*100);

    overallAcc = sum(diag(confMat_region)) / sum(confMat_region(:));
    class_precision = zeros(1,3);
    class_recall    = zeros(1,3);
    class_specificity = zeros(1,3);
    class_f1        = zeros(1,3);
    class_accuracy  = zeros(1,3);
    for c = 1:3
        TP = confMat_region(c,c);
        FP = sum(confMat_region(:,c)) - TP;
        FN = sum(confMat_region(c,:)) - TP;
        TN = sum(confMat_region(:)) - (TP+FP+FN);
        if (TP + FN) > 0
            class_accuracy(c) = TP / (TP + FN);
        else
            class_accuracy(c) = NaN;
        end
        if (TP + FP) > 0
            class_precision(c) = TP / (TP + FP);
        else
            class_precision(c) = NaN;
        end
        if (TP + FN) > 0
            class_recall(c) = TP / (TP + FN);
        else
            class_recall(c) = NaN;
        end
        if (TN + FP) > 0
            class_specificity(c) = TN / (TN + FP);
        else
            class_specificity(c) = NaN;
        end
        if ~isnan(class_precision(c)) && ~isnan(class_recall(c)) ...
                && (class_precision(c) + class_recall(c))>0
            class_f1(c) = 2*(class_precision(c)*class_recall(c)) ...
                            /(class_precision(c)+class_recall(c));
        else
            class_f1(c) = NaN;
        end
    end
    macro_precision   = mean(class_precision,   'omitnan');
    macro_recall      = mean(class_recall,      'omitnan');
    macro_specificity = mean(class_specificity, 'omitnan');
    macro_f1          = mean(class_f1,          'omitnan');
    mean_class_acc    = mean(class_accuracy,    'omitnan');

    fprintf('Fold %d => OverallAcc=%.2f%%, MacroPrec=%.2f%%, MacroRec=%.2f%%, MacroSpec=%.2f%%, MacroF1=%.2f%%\n',...
         fold, 100*overallAcc, 100*macro_precision, 100*macro_recall, 100*macro_specificity, 100*macro_f1);
    fprintf(' Class1(Awake) => Acc=%.2f%%, Prec=%.2f%%, Rec=%.2f%%, Spec=%.2f%%, F1=%.2f%%\n',...
         100*class_accuracy(1), 100*class_precision(1), 100*class_recall(1), ...
         100*class_specificity(1), 100*class_f1(1));
    fprintf(' Class2(Uncns) => Acc=%.2f%%, Prec=%.2f%%, Rec=%.2f%%, Spec=%.2f%%, F1=%.2f%%\n',...
         100*class_accuracy(2), 100*class_precision(2), 100*class_recall(2), ...
         100*class_specificity(2), 100*class_f1(2));
    fprintf(' Class3(Recov) => Acc=%.2f%%, Prec=%.2f%%, Rec=%.2f%%, Spec=%.2f%%, F1=%.2f%%\n',...
         100*class_accuracy(3), 100*class_precision(3), 100*class_recall(3), ...
         100*class_specificity(3), 100*class_f1(3));
    fprintf(' Average Class Accuracy=%.2f%%\n', 100*mean_class_acc);

    region_confMat_sum = region_confMat_sum + confMat_region;
    region_metrics_all(fold,:) = [overallAcc, macro_precision, macro_recall, macro_f1];

    %% 6A.3) Future BIS
    [Xtrain_futureBIS, BIS_future_train, subsetDataTrain_future] = ...
        shiftBISbyOffset(trainSet, Xtrain_BIS, BIStrain, future_BIS_offset);
    [Xtest_futureBIS,  BIS_future_test,  subsetDataTest_future]  = ...
        shiftBISbyOffset(testSet,  Xtest_BIS,  BIStest,  future_BIS_offset);

    corr_future_train = NaN; corr_future_test = NaN;
    rmse_future_train = NaN; mae_future_train = NaN;
    rmse_future_test  = NaN; mae_future_test  = NaN;
    if ~isempty(Xtrain_futureBIS) && ~isempty(Xtest_futureBIS)
        extraFeatureIdx = (301:312)';  
        futureBISfeatures = [finalBISfeatures; extraFeatureIdx];

        % accumulate data for ARD–GPR interpretability of future BIS
        ARD_future_X = [ARD_future_X; Xtrain_futureBIS(:, futureBISfeatures)];
        ARD_future_y = [ARD_future_y; BIS_future_train];

        futureBISmodel = fitrgp( ...
            Xtrain_futureBIS(:, futureBISfeatures), ...
            BIS_future_train, ...
            'KernelFunction','matern52', ...
            'BasisFunction', bestBISParams.BasisFunction, ...
            'Sigma',         bestBISParams.Sigma, ...
            'Standardize',   true, ...
            'FitMethod','sr', 'PredictMethod','sr');

        alpha = 0.10; % 90% CI
        [futureBIS_train_pred, ysd_train] = predict(futureBISmodel, Xtrain_futureBIS(:,futureBISfeatures));
        [futureBIS_test_pred,  ysd_test]  = predict(futureBISmodel, Xtest_futureBIS(:, futureBISfeatures));

        zVal = norminv((1 + 0.90)/2);  
        lower_train = futureBIS_train_pred - zVal*ysd_train;
        upper_train = futureBIS_train_pred + zVal*ysd_train;
        lower_test  = futureBIS_test_pred  - zVal*ysd_test;
        upper_test  = futureBIS_test_pred  + zVal*ysd_test;

        corr_future_train = corr(futureBIS_train_pred, BIS_future_train);
        corr_future_test  = corr(futureBIS_test_pred,  BIS_future_test);

        rmse_future_train = sqrt(mean((futureBIS_train_pred - BIS_future_train).^2));
        mae_future_train  = mean(abs(futureBIS_train_pred - BIS_future_train));
        rmse_future_test  = sqrt(mean((futureBIS_test_pred  - BIS_future_test).^2));
        mae_future_test   = mean(abs(futureBIS_test_pred  - BIS_future_test));

        coverageTrain = mean(BIS_future_train>=lower_train & BIS_future_train<=upper_train)*100;
        coverageTest  = mean(BIS_future_test >=lower_test  & BIS_future_test <=upper_test)*100;

        fprintf('Fold %d FutureBIS => CorrTrain=%.2f, CorrTest=%.2f (offset=%d)\n',...
            fold, corr_future_train, corr_future_test, future_BIS_offset);
        fprintf('                 => RMSE(Train)=%.2f, MAE(Train)=%.2f, RMSE(Test)=%.2f, MAE(Test)=%.2f\n',...
            rmse_future_train, mae_future_train, rmse_future_test, mae_future_test);
        fprintf('CoverageTrain=%.2f%%, CoverageTest=%.2f%% (90%% CI)\n', ...
            coverageTrain, coverageTest);

        % store into allFolds arrays for plotting later
        allFolds_futureTestSet{fold}  = subsetDataTest_future;
        allFolds_futurePredBIS{fold}  = futureBIS_test_pred;
        allFolds_futureLower{fold}    = lower_test;
        allFolds_futureUpper{fold}    = upper_test;
    end

    correlation_futureBIS = [correlation_futureBIS; ...
        corr_future_train, corr_future_test, ...
        rmse_future_train, mae_future_train, rmse_future_test, mae_future_test];

    % Bland-Altman Plot for Future BIS Prediction (Test Set)
    if exist('futureBIS_test_pred','var') && ~isempty(futureBIS_test_pred)
        mean_futureBIS = mean([futureBIS_test_pred, BIS_future_test], 2);
        diff_futureBIS = futureBIS_test_pred - BIS_future_test;

        bias_future = mean(diff_futureBIS);
        sd_diff_future = std(diff_futureBIS);
        loa_upper_future = bias_future + 1.96 * sd_diff_future;
        loa_lower_future = bias_future - 1.96 * sd_diff_future;

        figure;
        scatter(mean_futureBIS, diff_futureBIS, 25, 'filled', 'MarkerFaceAlpha', 0.6);
        hold on;
        yline(bias_future, 'k--', 'LineWidth', 1.5, 'Label', 'Mean Bias');
        yline(loa_upper_future, 'r--', 'LineWidth', 1.5, 'Label', '+1.96 SD');
        yline(loa_lower_future, 'r--', 'LineWidth', 1.5, 'Label', '-1.96 SD');

        xlabel('Mean of Predicted and Actual Future BIS');
        ylabel('Difference (Predicted - Actual)');
        title(sprintf('Bland-Altman Plot of Future BIS Prediction (Fold %d)', fold));
        grid on;
        hold off;
    end

    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
    %% 6B) TTT Model with Expanded Training Cap
    %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

    % 0) Keep references to original TTT (unclamped)
    TTTtrain_orig = TTTtrain;  % the raw TTT from the dataset
    TTTtest_orig  = TTTtest;

    Xtrain_TTT = Xtrain_BIS;
    Xtest_TTT  = Xtest_BIS;

    % 1) Define an expanded clamp for training
    trainingMaxWindow = max_windows + 1;   % e.g. if max_windows=15, then trainingMaxWindow=25

    % 2) Clamp TTT at ±(max_windows+10) for training and test
    TTTtrain_clamped = max(min(TTTtrain, trainingMaxWindow), -trainingMaxWindow);
    TTTtest_clamped  = max(min(TTTtest,  trainingMaxWindow), -trainingMaxWindow);

    % 3) Downsample extremes on the training set
    idx_cap_train = (TTTtrain_clamped == trainingMaxWindow | TTTtrain_clamped == -trainingMaxWindow);
    nCapTrain     = sum(idx_cap_train);
    nNonCapTrain  = sum(~idx_cap_train);

    keepTrainN = min(nCapTrain, nNonCapTrain);
    if nCapTrain > 0
        cap_inds_train    = find(idx_cap_train);
        dsampled_cap_inds = datasample(cap_inds_train, keepTrainN, 'Replace', false);
        finalTrain_inds   = [find(~idx_cap_train); dsampled_cap_inds];
    else
        finalTrain_inds   = 1:length(TTTtrain_clamped);
    end

    idx_cap_test = (TTTtest_clamped == trainingMaxWindow | TTTtest_clamped == -trainingMaxWindow);
    nCapTest     = sum(idx_cap_test);
    nNonCapTest  = sum(~idx_cap_test);
    keepTestN    = min(nCapTest, nNonCapTest);

    if nCapTest > 0
        cap_inds_test          = find(idx_cap_test);
        dsampled_cap_inds_test = datasample(cap_inds_test, keepTestN, 'Replace', false);
        finalTest_inds         = [find(~idx_cap_test); dsampled_cap_inds_test];
    else
        finalTest_inds         = 1:length(TTTtest_clamped);
    end

    Xtrain_TTT_down = Xtrain_BIS(finalTrain_inds, :);
    TTTtrain_down   = TTTtrain_clamped(finalTrain_inds);

    Xtest_TTT_down  = Xtest_BIS(finalTest_inds, :);
    TTTtest_down    = TTTtest_clamped(finalTest_inds);

    allExtraTTT       = (301:312)'; 
    TTT_model_features= [finalTTTfeatures; allExtraTTT];

    hiddenLayerSizes_TTT = [100, 50, 15];

    Xtrain_TTT_nn = Xtrain_TTT_down(:, TTT_model_features)';
    Ytrain_TTT_nn = TTTtrain_down';   % [1 x numTrainSamples]

    net_TTT = fitnet(hiddenLayerSizes_TTT, 'trainscg');
    net_TTT.trainParam.showWindow = false;
    net_TTT.trainParam.epochs     = 1000;
    net_TTT.trainParam.max_fail   = 10;

    [net_TTT, ~] = train(net_TTT, Xtrain_TTT_nn, Ytrain_TTT_nn);

    Xtrain_TTT_nn_full = Xtrain_BIS(:, TTT_model_features)';
    predTrain_nn_full  = net_TTT(Xtrain_TTT_nn_full);
    pseudoTTT_train    = predTrain_nn_full(:);

    pseudoTTT_train = max(min(pseudoTTT_train, trainingMaxWindow), -trainingMaxWindow);

    Xtest_TTT_nn_full  = Xtest_BIS(:, TTT_model_features)';
    predTest_nn_full   = net_TTT(Xtest_TTT_nn_full);
    pseudoTTT_test     = predTest_nn_full(:);

    pseudoTTT_test = max(min(pseudoTTT_test, trainingMaxWindow), -trainingMaxWindow);

    corrTrain_TTT = corr(pseudoTTT_train, TTTtrain_clamped);
    corrTest_TTT  = corr(pseudoTTT_test,  TTTtest_clamped);

    rmseTrain = sqrt(mean((pseudoTTT_train - TTTtrain_clamped).^2));
    rmseTest  = sqrt(mean((pseudoTTT_test  - TTTtest_clamped).^2));
    maeTrain  = mean(abs(pseudoTTT_train - TTTtrain_clamped));
    maeTest   = mean(abs(pseudoTTT_test  - TTTtest_clamped));

    fprintf('Fold %d TTT => Corr(Train)=%.2f, RMSE(Train)=%.2f, MAE(Train)=%.2f\n',...
        fold, corrTrain_TTT, rmseTrain, maeTrain);
    fprintf('Fold %d TTT => Corr(Test)=%.2f,  RMSE(Test)=%.2f,  MAE(Test)=%.2f\n',...
        fold, corrTest_TTT, rmseTest, maeTest);

    inRegionIdx = find(abs(TTTtest_orig) < max_windows);
    if ~isempty(inRegionIdx)
        corrTest_inRegion = corr(pseudoTTT_test(inRegionIdx), TTTtest_orig(inRegionIdx));
        rmseTest_inRegion = sqrt(mean((pseudoTTT_test(inRegionIdx) - TTTtest_orig(inRegionIdx)).^2));
        maeTest_inRegion  = mean(abs(pseudoTTT_test(inRegionIdx) - TTTtest_orig(inRegionIdx)));
        fprintf('Fold %d TTT (In-Region ±%d) => Corr=%.2f, RMSE=%.2f, MAE=%.2f\n',...
            fold, max_windows, corrTest_inRegion, rmseTest_inRegion, maeTest_inRegion);
    else
        corrTest_inRegion = NaN;
        rmseTest_inRegion = NaN;
        maeTest_inRegion  = NaN;
        fprintf('Fold %d TTT (In-Region ±%d): No test samples.\n', fold, max_windows);
    end

    correlation_metrics = [correlation_metrics; ...
        corrTrain_TTT, corrTest_TTT, corrTest_inRegion, rmseTest_inRegion, maeTest_inRegion];

    %% 6C) Classification (with TTT as feature)
    Xtrain_Clf = [Xtrain_TTT, pseudoTTT_train];
    Xtest_Clf  = [Xtest_TTT,  pseudoTTT_test];

    allExtraCLF_features = (301:313)'; 
    finalClassFeatures = [finalClassFeatures; allExtraCLF_features];

    class0_idx = find(StateTrain==0);
    class1_idx = find(StateTrain==1);
    featsClass0 = Xtrain_Clf(class0_idx,:);
    featsClass1 = Xtrain_Clf(class1_idx,:);
    dsSize = round(size(featsClass0,1)*downsample_ratio);
    dsSize = min(dsSize, size(featsClass0,1));
    dsample_class0_idx = datasample(class0_idx, dsSize, 'Replace', false);
    dsample_featsClass0= Xtrain_Clf(dsample_class0_idx, :);
    num_overlap = round(dsSize*(overlap_ratio-1));
    ensemble_models = {};
    subset_start = 1;
    iteration=0;
    while subset_start <= size(dsample_featsClass0,1)
        iteration = iteration+1;
        subset_end = min(subset_start+num_overlap-1, size(dsample_featsClass0,1));
        class0_sub = dsample_featsClass0(subset_start:subset_end, finalClassFeatures);

        neededSyn = max(0, size(class0_sub,1) - size(featsClass1,1));
        syn_min   = smote(featsClass1(:, finalClassFeatures), neededSyn, k_neighbors);

        ensemble_feats  = [class0_sub; featsClass1(:, finalClassFeatures); syn_min];
        ensemble_labels = [zeros(size(class0_sub,1),1);
                           ones(size(featsClass1,1),1);
                           ones(size(syn_min,1),1)];

        sh = randperm(size(ensemble_feats,1));
        ensemble_feats  = ensemble_feats(sh,:);
        ensemble_labels = ensemble_labels(sh);

        model_rf = TreeBagger(100, ensemble_feats, ensemble_labels, ...
            'Method','classification', 'OOBPrediction','on', ...
            'MinLeafSize', min_leaf_size, 'MaxNumSplits', max_num_splits);
        ensemble_models{iteration} = model_rf;
        subset_start = subset_end + 1;
    end

    testDataClf = Xtest_Clf(:, finalClassFeatures);
    all_preds = zeros(size(testDataClf,1), length(ensemble_models));
    for b = 1:length(ensemble_models)
        pred_labels = predict(ensemble_models{b}, testDataClf);
        all_preds(:, b) = str2double(pred_labels);
    end
    final_preds = mode(all_preds, 2);

    confMat = confusionmat(StateTest, final_preds, 'Order',[0,1]);
    disp(['Fold ', num2str(fold), ' Confusion Matrix (Binary):']);
    disp(confMat);
    clf2_confMat_sum = clf2_confMat_sum + confMat;

    class_accuracy   = zeros(1,2);
    class_precision  = zeros(1,2);
    class_recall     = zeros(1,2);
    class_specificity= zeros(1,2);
    class_f1         = zeros(1,2);

    for cIdx = 1:2
        TP = confMat(cIdx,cIdx);
        FP = sum(confMat(:,cIdx)) - TP;
        FN = sum(confMat(cIdx,:)) - TP;
        TN = sum(confMat(:)) - (TP+FP+FN);

        if (TP+FN)>0
            class_accuracy(cIdx) = TP/(TP+FN);
        else
            class_accuracy(cIdx) = NaN;
        end
        if (TP+FP)>0
            class_precision(cIdx)= TP/(TP+FP);
        else
            class_precision(cIdx)= NaN;
        end
        if (TP+FN)>0
            class_recall(cIdx)   = TP/(TP+FN);
        else
            class_recall(cIdx)   = NaN;
        end
        if (TN+FP)>0
            class_specificity(cIdx)= TN/(TN+FP);
        else
            class_specificity(cIdx)= NaN;
        end
        prec = class_precision(cIdx);
        rec  = class_recall(cIdx);
        if ~(isnan(prec) || isnan(rec)) && (prec+rec)>0
            class_f1(cIdx) = 2*(prec*rec)/(prec+rec);
        else
            class_f1(cIdx) = NaN;
        end
    end
    overall_acc = sum(diag(confMat))/sum(confMat(:));
    macro_prec  = nanmean(class_precision);
    macro_rec   = nanmean(class_recall);
    macro_spec  = nanmean(class_specificity);
    macro_f1    = nanmean(class_f1);

    fprintf('Fold %d Classification => Overall=%.2f%%, MacroPrec=%.2f%%, MacroRec=%.2f%%, MacroSpec=%.2f%%, MacroF1=%.2f%%\n',...
        fold, overall_acc*100, macro_prec*100, macro_rec*100, macro_spec*100, macro_f1*100);
    fprintf('   Class 0 => Acc=%.2f%%, Prec=%.2f%%, Rec=%.2f%%, Spec=%.2f%%, F1=%.2f%%\n',...
        class_accuracy(1)*100, class_precision(1)*100, class_recall(1)*100, class_specificity(1)*100, class_f1(1)*100);
    fprintf('   Class 1 => Acc=%.2f%%, Prec=%.2f%%, Rec=%.2f%%, Spec=%.2f%%, F1=%.2f%%\n',...
        class_accuracy(2)*100, class_precision(2)*100, class_recall(2)*100, class_specificity(2)*100, class_f1(2)*100);

    rfMetrics = [rfMetrics; ...
        overall_acc, macro_prec, macro_rec, macro_spec, macro_f1, ...
        class_accuracy(1), class_precision(1), class_recall(1), class_specificity(1), class_f1(1), ...
        class_accuracy(2), class_precision(2), class_recall(2), class_specificity(2), class_f1(2)];

    %%% NEW %%% - Store this fold's testSet, predictions, final_probs, etc.
    allFolds_testSet{fold}      = testSet; 
    allFolds_predictedBIS{fold} = predictedBIS_test;

    % Probability from each ensemble
    all_probs = zeros(size(testDataClf,1), length(ensemble_models));
    for m = 1:length(ensemble_models)
        [~,scores] = predict(ensemble_models{m}, testDataClf);
        all_probs(:,m) = scores(:,2);
    end
    final_probs = mean(all_probs,2);
    allFolds_finalProbs{fold}      = final_probs;
    allFolds_ensemble_models{fold} = ensemble_models;

end % end for fold=1:k

