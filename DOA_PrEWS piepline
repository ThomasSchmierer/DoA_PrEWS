class_labels   = zeros(num_data, 1);
region_labels  = strings(num_data, 1);

for i = 1:num_data
    X_all(i,:)     = reshape(all_data(i).EEG, 1, []);
    BIS_targets(i) = all_data(i).BISMedian;
    TTT_targets(i) = all_data(i).time_to_target;
    class_labels(i)= str2double(all_data(i).state);

    if isfield(all_data(i), 'region_label')
        region_labels(i) = all_data(i).region_label;
    else
        region_labels(i) = "Unknown";
    end
end

disp('Flattening complete. region_labels assigned (Unknown if missing).');

%% 4.1 Feature selection with Saving
useSaved = 0 ;

if useSaved == 1
    saveFileName = "C:\Research project Backup 05072025\Research Project\All_features\LoC_Prediction\LoCV2\parameters\Features\saved_features_LoC_Feats_30s_window_5_features.mat";
    
    if exist(saveFileName, 'file')
