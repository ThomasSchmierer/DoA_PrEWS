                    p_bis    = [localTestSet(p_inds).BISMedian];
                    p_bisP   = localPredBIS(p_inds);
                    p_prob   = localProbs(p_inds);
                    p_states = [localTestSet(p_inds).state];

                    [p_times, ixS] = sort(p_times);
                    p_bis    = p_bis(ixS);
                    p_bisP   = p_bisP(ixS);
                    p_prob   = p_prob(ixS);
                    p_states = p_states(ixS);

                    figure('Name', ['Fold ', num2str(f), ', Patient ', num2str(pid)], 'Color','w');
                    yyaxis left
                    hold on;
                    plot(p_times, p_bis, '-o', 'LineWidth', 2, 'Color','b');
                    plot(p_times, p_bisP, '-x', 'LineWidth', 2, 'Color','g');
                    ylabel('BIS Actual & Predicted');
                    xlabel('Window Time');

                    yyaxis right
                    plot(p_times, p_prob, '-s', 'LineWidth', 2, 'Color','r');
                    ylabel('Prob(Target=1)');
                    grid on;
                    title(['Fold ', num2str(f), ', Patient ', num2str(pid), ': BIS vs. PredBIS vs. Target Prob']);
                    legend({'BIS','DoA-Current-GPR','P(Target=1)'}, 'Location','best');

                    tIdx = find(p_states=='1',1,'first');
                    if ~isempty(tIdx)
                        tWin = p_times(tIdx);
                        xline(tWin,'--k','LineWidth',2,'Label','Target','LabelOrientation','horizontal');
                        xlim([tWin - max_windows, tWin + max_windows]);
                    end
                    hold off;
                end
            end

            fTestSet = allFolds_futureTestSet{f};
            fPred    = allFolds_futurePredBIS{f};
            fLow     = allFolds_futureLower{f};
            fUp      = allFolds_futureUpper{f};
            if isempty(fTestSet), continue; end

            offsetShift = -future_BIS_offset;
            localPIDs = unique([fTestSet.Patient_ID]);
            for p = 1:length(localPIDs)
                pid = localPIDs(p);
                pat_inds = find([fTestSet.Patient_ID] == pid);

                pat_times       = [fTestSet(pat_inds).Window_future];
                pat_BIS_current = [fTestSet(pat_inds).BISMedian];
                pat_BISpred     = fPred(pat_inds);
                pat_low         = fLow(pat_inds);
                pat_up          = fUp(pat_inds);

                [pat_times, idxS] = sort(pat_times);
                pat_BIS_current = pat_BIS_current(idxS);
                pat_BISpred     = pat_BISpred(idxS);
                pat_low         = pat_low(idxS);
                pat_up          = pat_up(idxS);

                shifted_times_pred = pat_times + offsetShift;
                validIdx = (shifted_times_pred >= 0);
                if all(~validIdx), continue; end

                pat_times       = pat_times(validIdx);
                pat_BIS_current = pat_BIS_current(validIdx);
                pat_BISpred     = pat_BISpred(validIdx);
                pat_low         = pat_low(validIdx);
                pat_up          = pat_up(validIdx);
                shifted_times_pred= shifted_times_pred(validIdx);

                figure('Name', ['Fold ', num2str(f), ', Patient ', num2str(pid), ' FUTURE BIS'], 'Color','w');
                hold on;
                plot(pat_times, pat_BIS_current, '-o', 'LineWidth',2, 'Color','b');
                plot(shifted_times_pred, pat_BISpred, '-s', 'LineWidth',2, 'Color','r');
                plot(shifted_times_pred, pat_low, '--r', 'LineWidth',1.5);
                plot(shifted_times_pred, pat_up,  '--r', 'LineWidth',1.5);

                xlabel('Window Time');
                ylabel('BIS');
                legend({'Actual Current BIS','Predicted Future BIS','Lower Bound','Upper Bound'}, ...
                    'Location','best');
                title(['Future BIS: Fold ', num2str(f), ', Patient ', num2str(pid)]);
                grid on;
                hold off;
            end
        end

    case 2
        f = k;
        fprintf('\n[PlotMode=2] => Plotting all patients from final fold (fold=%d).\n', f);

        localTestSet = allFolds_testSet{f};
        localPredBIS = allFolds_predictedBIS{f};
        localProbs   = allFolds_finalProbs{f};
        if ~isempty(localTestSet) && ~isempty(localProbs)
            uniquePIDs = unique([localTestSet.Patient_ID]);
            for p = 1:length(uniquePIDs)
                pid = uniquePIDs(p);
                p_inds = find([localTestSet.Patient_ID] == pid);

                p_times  = [localTestSet(p_inds).Window];
                p_bis    = [localTestSet(p_inds).BISMedian];
                p_bisP   = localPredBIS(p_inds);
                p_prob   = localProbs(p_inds);
                p_states = [localTestSet(p_inds).state];

                [p_times, ixS] = sort(p_times);
                p_bis    = p_bis(ixS);
                p_bisP   = p_bisP(ixS);
                p_prob   = p_prob(ixS);
                p_states = p_states(ixS);

                figure('Name', ['FinalFold Patient ', num2str(pid)], 'Color','w');
                yyaxis left
                hold on;
                plot(p_times, p_bis,  '-o', 'LineWidth',2, 'Color','b');
                plot(p_times, p_bisP, '-x', 'LineWidth',2, 'Color','g');
                ylabel('BIS Actual & Predicted');
                xlabel('Window Time');

                yyaxis right
                plot(p_times, p_prob, '-s', 'LineWidth',2, 'Color','r');
                ylabel('Prob(Target=1)');
                grid on;
                title(['Fold ', num2str(f), ', Patient ', num2str(pid)]);
                legend({'BIS(Actual)','BIS(Pred)','P(Target=1)'}, 'Location','best');

                tIdx = find(p_states=='1',1,'first');
                if ~isempty(tIdx)
                    tWin = p_times(tIdx);
                    xline(tWin,'--k','LineWidth',2,'Label','Target','LabelOrientation','horizontal');
                    xlim([tWin - max_windows, tWin + max_windows]);
                end
                hold off;
            end
        end

        fTestSet  = allFolds_futureTestSet{f};
        fPred     = allFolds_futurePredBIS{f};
        fLow      = allFolds_futureLower{f};
        fUp       = allFolds_futureUpper{f};
        if ~isempty(fTestSet)
            offsetShift = -future_BIS_offset;
            localPIDs = unique([fTestSet.Patient_ID]);
            for p = 1:length(localPIDs)
                pid = localPIDs(p);
                pat_inds = find([fTestSet.Patient_ID] == pid);

                pat_times       = [fTestSet(pat_inds).Window_future];
                pat_BIS_current = [fTestSet(pat_inds).BISMedian];
                pat_BISpred     = fPred(pat_inds);
                pat_low         = fLow(pat_inds);
                pat_up          = fUp(pat_inds);

                [pat_times, idxS] = sort(pat_times);
                pat_BIS_current = pat_BIS_current(idxS);
                pat_BISpred     = pat_BISpred(idxS);
                pat_low         = pat_low(idxS);
                pat_up          = pat_up(idxS);

                shifted_times_pred = pat_times + offsetShift;
                validIdx = shifted_times_pred >= 0;
                if all(~validIdx), continue; end

                pat_times       = pat_times(validIdx);
                pat_BIS_current = pat_BIS_current(validIdx);
                pat_BISpred     = pat_BISpred(validIdx);
                pat_low         = pat_low(validIdx);
                pat_up          = pat_up(validIdx);
                shifted_times_pred = shifted_times_pred(validIdx);

                figure('Name',['FinalFold Future BIS, Pt ', num2str(pid)], 'Color','w');
                hold on;
                plot(pat_times, pat_BIS_current, '-o', 'LineWidth',2, 'Color','b');
                plot(shifted_times_pred, pat_BISpred, '-s', 'LineWidth',2, 'Color','r');
                plot(shifted_times_pred, pat_low, '--r', 'LineWidth',1.5);
                plot(shifted_times_pred, pat_up,  '--r', 'LineWidth',1.5);

                xlabel('Window Time');
                ylabel('BIS');
                legend({'Actual Current BIS','Predicted Future BIS','Lower Bound','Upper Bound'}, ...
                    'Location','best');
                title(['Future BIS: Fold ', num2str(f), ', Patient ', num2str(pid)]);
                grid on;
                hold off;
            end
        end

    case 3
        fprintf('\n[PlotMode=3] => Plotting only selected patients, for *all folds*.\n');
        for f = 1:k
            fprintf('   => Fold %d:\n', f);

            localTestSet = allFolds_testSet{f};
            localPredBIS = allFolds_predictedBIS{f};
            localProbs   = allFolds_finalProbs{f};
            if isempty(localTestSet) || isempty(localProbs), continue; end

            for pid = selectedPatients
                p_inds = find([localTestSet.Patient_ID] == pid);
                if isempty(p_inds), continue; end

                p_times  = [localTestSet(p_inds).Window];
                p_bis    = [localTestSet(p_inds).BISMedian];
                p_bisP   = localPredBIS(p_inds);
                p_prob   = localProbs(p_inds);
                p_states = [localTestSet(p_inds).state];

                [p_times, ixS] = sort(p_times);
                p_bis    = p_bis(ixS);
                p_bisP   = p_bisP(ixS);
                p_prob   = p_prob(ixS);
                p_states = p_states(ixS);

                figure('Name',['Fold ', num2str(f), ', Selected Pt ', num2str(pid)], 'Color','w');
                yyaxis left
                hold on;
                plot(p_times, p_bis,  '-o', 'LineWidth',2, 'Color','b');
                plot(p_times, p_bisP, '-x', 'LineWidth',2, 'Color','g');
                ylabel('BIS');
                xlabel('Window Time');

                yyaxis right
                plot(p_times, p_prob, '-s', 'LineWidth',2, 'Color','r');
                ylabel('Probability');
                ylim([0 1]);
                grid on;
                title(['Fold ', num2str(f), ', Patient ', num2str(pid)]);
                legend({'BIS','DoA-Current-GPR','Probability Target'}, 'Location','best')

                tIdx = find(p_states=='1',1,'first');
                if ~isempty(tIdx)
                    tWin = p_times(tIdx);
                    xline(tWin,'--k','LineWidth',2,'Label','Target','LabelOrientation','horizontal');
                    xlim([tWin - max_windows, tWin + max_windows]);
                end
                hold off;
            end

            fTestSet = allFolds_futureTestSet{f};
            fPred    = allFolds_futurePredBIS{f};
            fLow     = allFolds_futureLower{f};
            fUp      = allFolds_futureUpper{f};
            if isempty(fTestSet), continue; end

            offsetShift = -future_BIS_offset;

            for pid = selectedPatients
                pat_inds = find([fTestSet.Patient_ID] == pid);
                if isempty(pat_inds), continue; end

                pat_times       = [fTestSet(pat_inds).Window_future];
                pat_BIS_current = [fTestSet(pat_inds).BISMedian];
                pat_BISpred_future = fPred(pat_inds);
                pat_BISpred_low    = fLow(pat_inds);
                pat_BISpred_up     = fUp(pat_inds);
                pat_BISpred_current = allFolds_predictedBIS{f}(ismember([allFolds_testSet{f}.Patient_ID], pid)); 

                [pat_times, idxS] = sort(pat_times);
                pat_BIS_current     = pat_BIS_current(idxS);
                pat_BISpred_future  = pat_BISpred_future(idxS);
                pat_BISpred_low     = pat_BISpred_low(idxS);
                pat_BISpred_up      = pat_BISpred_up(idxS);

                shifted_times_pred = pat_times + offsetShift;
                validIdx = shifted_times_pred >= 0;
                if all(~validIdx)
                    fprintf('Fold %d, Patient %d: All shifted times are negative, skipping.\n', f, pid);
                    continue;
                end

                pat_times       = pat_times(validIdx);
                pat_BIS_current = pat_BIS_current(validIdx);
                pat_BISpred_future  = pat_BISpred_future(validIdx);
                pat_BISpred_low     = pat_BISpred_low(validIdx);
                pat_BISpred_up      = pat_BISpred_up(validIdx);
                shifted_times_pred  = shifted_times_pred(validIdx);

                figure('Name',['Fold ', num2str(f), ' - Patient ', num2str(pid), ' FUTURE BIS'], 'Color','w');
                hold on;
                plot(pat_times, pat_BIS_current, '-o', 'LineWidth', 2, 'Color', 'b');
                plot(shifted_times_pred, pat_BISpred_future, '-x', 'LineWidth', 2, 'Color', 'r');
                plot(shifted_times_pred, pat_BISpred_low, '--r', 'LineWidth', 1.5);
                plot(shifted_times_pred, pat_BISpred_up,  '--r', 'LineWidth', 1.5);

                legend({'BIS','DoA-Future-GPR', ...
                        'Prediction Lower Bound','Prediction Upper Bound'}, ...
                       'Location','best');
                xlabel('Period');
                ylabel('BIS');
                title(['Future BIS: Fold ', num2str(f), ', Patient ', num2str(pid)]);
                grid on;
                hold off;
            end
        end

    otherwise
        fprintf('\nUnknown plotMode=%d => No plots.\n', plotMode);
end
