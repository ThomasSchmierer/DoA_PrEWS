%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 6B) TTT Model with Expanded Training Cap
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% 0) Keep references to original TTT (unclamped)
TTTtrain_orig = TTTtrain;  % the raw TTT from the dataset
TTTtest_orig  = TTTtest;

Xtrain_TTT = Xtrain_BIS;
Xtest_TTT  = Xtest_BIS;

% 1) Define an expanded clamp for training
trainingMaxWindow = max_windows + 1;   % e.g. if max_windows=15, then trainingMaxWindow=25

% 2) Clamp TTT at ±(max_windows+10) for training and test
TTTtrain_clamped = max(min(TTTtrain, trainingMaxWindow), -trainingMaxWindow);
TTTtest_clamped  = max(min(TTTtest,  trainingMaxWindow), -trainingMaxWindow);

% 3) Downsample extremes on the training set so that boundary points
%    near ±(trainingMaxWindow) do not dominate.
idx_cap_train = (TTTtrain_clamped == trainingMaxWindow | TTTtrain_clamped == -trainingMaxWindow);
nCapTrain     = sum(idx_cap_train);
nNonCapTrain  = sum(~idx_cap_train);

% Keep at most "min(nCapTrain, nNonCapTrain)" of the boundary points
keepTrainN = min(nCapTrain, nNonCapTrain);
if nCapTrain > 0
    cap_inds_train    = find(idx_cap_train);
    dsampled_cap_inds = datasample(cap_inds_train, keepTrainN, 'Replace', false);
    finalTrain_inds   = [find(~idx_cap_train); dsampled_cap_inds];
else
    finalTrain_inds   = 1:length(TTTtrain_clamped);
end

% (Optional) Downsample extremes in TTTtest_clamped similarly (or not).
idx_cap_test = (TTTtest_clamped == trainingMaxWindow | TTTtest_clamped == -trainingMaxWindow);
nCapTest     = sum(idx_cap_test);
nNonCapTest  = sum(~idx_cap_test);
keepTestN    = min(nCapTest, nNonCapTest);

if nCapTest > 0
    cap_inds_test          = find(idx_cap_test);
    dsampled_cap_inds_test = datasample(cap_inds_test, keepTestN, 'Replace', false);
    finalTest_inds         = [find(~idx_cap_test); dsampled_cap_inds_test];
else
    finalTest_inds         = 1:length(TTTtest_clamped);
end

% 4) Subset features and TTT accordingly for training the NN
Xtrain_TTT_down = Xtrain_BIS(finalTrain_inds, :);
TTTtrain_down   = TTTtrain_clamped(finalTrain_inds);

Xtest_TTT_down  = Xtest_BIS(finalTest_inds, :);
TTTtest_down    = TTTtest_clamped(finalTest_inds);

% 5) Define the feature indices for TTT model (already selected earlier)
allExtraTTT       = (301:312)'; 
TTT_model_features= [finalTTTfeatures; allExtraTTT];

% 6) Train the feedforward neural network on the downsampled set
hiddenLayerSizes_TTT = [100, 50, 15];

Xtrain_TTT_nn = Xtrain_TTT_down(:, TTT_model_features)';
Ytrain_TTT_nn = TTTtrain_down';   % [1 x numTrainSamples]

net_TTT = fitnet(hiddenLayerSizes_TTT, 'trainscg');
net_TTT.trainParam.showWindow = false;
net_TTT.trainParam.epochs     = 1000;
net_TTT.trainParam.max_fail   = 10;

[net_TTT, ~] = train(net_TTT, Xtrain_TTT_nn, Ytrain_TTT_nn);

% 7) Predict TTT on the *full* TRAIN set (unfiltered)
Xtrain_TTT_nn_full = Xtrain_BIS(:, TTT_model_features)';
predTrain_nn_full  = net_TTT(Xtrain_TTT_nn_full);
pseudoTTT_train    = predTrain_nn_full(:);

% 8) Also clamp predictions to ±(trainingMaxWindow) to be consistent
pseudoTTT_train = max(min(pseudoTTT_train, trainingMaxWindow), -trainingMaxWindow);

% 9) Predict TTT on the *full* TEST set
Xtest_TTT_nn_full  = Xtest_BIS(:, TTT_model_features)';
predTest_nn_full   = net_TTT(Xtest_TTT_nn_full);
pseudoTTT_test     = predTest_nn_full(:);

% 10) Clamp predicted test TTT to ±(trainingMaxWindow)
pseudoTTT_test = max(min(pseudoTTT_test, trainingMaxWindow), -trainingMaxWindow);

% 11) Evaluate performance on the entire (original) TTT range
corrTrain_TTT = corr(pseudoTTT_train, TTTtrain_clamped);
corrTest_TTT  = corr(pseudoTTT_test,  TTTtest_clamped);

rmseTrain = sqrt(mean((pseudoTTT_train - TTTtrain_clamped).^2));
rmseTest  = sqrt(mean((pseudoTTT_test  - TTTtest_clamped).^2));
maeTrain  = mean(abs(pseudoTTT_train - TTTtrain_clamped));
maeTest   = mean(abs(pseudoTTT_test  - TTTtest_clamped));

fprintf('Fold %d TTT => Corr(Train)=%.2f, RMSE(Train)=%.2f, MAE(Train)=%.2f\n',...
    fold, corrTrain_TTT, rmseTrain, maeTrain);
fprintf('Fold %d TTT => Corr(Test)=%.2f,  RMSE(Test)=%.2f,  MAE(Test)=%.2f\n',...
    fold, corrTest_TTT, rmseTest, maeTest);

% 12) Evaluate “in‐region” performance (±15) using the original TTT
inRegionIdx = find(abs(TTTtest_orig) < max_windows);
if ~isempty(inRegionIdx)
    corrTest_inRegion = corr(pseudoTTT_test(inRegionIdx), TTTtest_orig(inRegionIdx));
    rmseTest_inRegion = sqrt(mean((pseudoTTT_test(inRegionIdx) - TTTtest_orig(inRegionIdx)).^2));
    maeTest_inRegion  = mean(abs(pseudoTTT_test(inRegionIdx) - TTTtest_orig(inRegionIdx)));
    fprintf('Fold %d TTT (In-Region ±%d) => Corr=%.2f, RMSE=%.2f, MAE=%.2f\n',...
        fold, max_windows, corrTest_inRegion, rmseTest_inRegion, maeTest_inRegion);
else
    corrTest_inRegion = NaN;
    rmseTest_inRegion = NaN;
    maeTest_inRegion  = NaN;
    fprintf('Fold %d TTT (In-Region ±%d): No test samples.\n', fold, max_windows);
end

% 13) Store or aggregate these metrics as usual
correlation_metrics = [correlation_metrics; ...
    corrTrain_TTT, corrTest_TTT, corrTest_inRegion, rmseTest_inRegion, maeTest_inRegion];



    %% 6C) Classification (with TTT as feature)
    Xtrain_Clf = [Xtrain_TTT, pseudoTTT_train];
    Xtest_Clf  = [Xtest_TTT,  pseudoTTT_test];

    allExtraCLF_features = (301:313)'; 
    finalClassFeatures = [finalClassFeatures; allExtraCLF_features];

    class0_idx = find(StateTrain==0);
    class1_idx = find(StateTrain==1);
    featsClass0 = Xtrain_Clf(class0_idx,:);
    featsClass1 = Xtrain_Clf(class1_idx,:);
    dsSize = round(size(featsClass0,1)*downsample_ratio);
    dsSize = min(dsSize, size(featsClass0,1));
    dsample_class0_idx = datasample(class0_idx, dsSize, 'Replace', false);
    dsample_featsClass0= Xtrain_Clf(dsample_class0_idx, :);
    num_overlap = round(dsSize*(overlap_ratio-1));
    ensemble_models = {};
    subset_start = 1;
    iteration=0;
    while subset_start <= size(dsample_featsClass0,1)
        iteration = iteration+1;
        subset_end = min(subset_start+num_overlap-1, size(dsample_featsClass0,1));
        class0_sub = dsample_featsClass0(subset_start:subset_end, finalClassFeatures);

        neededSyn = max(0, size(class0_sub,1) - size(featsClass1,1));
        syn_min   = smote(featsClass1(:, finalClassFeatures), neededSyn, k_neighbors);

        ensemble_feats  = [class0_sub; featsClass1(:, finalClassFeatures); syn_min];
        ensemble_labels = [zeros(size(class0_sub,1),1);
                           ones(size(featsClass1,1),1);
                           ones(size(syn_min,1),1)];

        sh = randperm(size(ensemble_feats,1));
        ensemble_feats  = ensemble_feats(sh,:);
        ensemble_labels = ensemble_labels(sh);

        model_rf = TreeBagger(100, ensemble_feats, ensemble_labels, ...
            'Method','classification', 'OOBPrediction','on', ...
            'MinLeafSize', min_leaf_size, 'MaxNumSplits', max_num_splits);
        ensemble_models{iteration} = model_rf;
        subset_start = subset_end + 1;
    end

    testDataClf = Xtest_Clf(:, finalClassFeatures);
    all_preds = zeros(size(testDataClf,1), length(ensemble_models));
    for b = 1:length(ensemble_models)
        pred_labels = predict(ensemble_models{b}, testDataClf);
        all_preds(:, b) = str2double(pred_labels);
    end
    final_preds = mode(all_preds, 2);

    confMat = confusionmat(StateTest, final_preds, 'Order',[0,1]);
    disp(['Fold ', num2str(fold), ' Confusion Matrix (Binary):']);
    disp(confMat);
    clf2_confMat_sum = clf2_confMat_sum + confMat;

    class_accuracy   = zeros(1,2);
    class_precision  = zeros(1,2);
    class_recall     = zeros(1,2);
    class_specificity= zeros(1,2);
    class_f1         = zeros(1,2);

    for cIdx = 1:2
        TP = confMat(cIdx,cIdx);
        FP = sum(confMat(:,cIdx)) - TP;
        FN = sum(confMat(cIdx,:)) - TP;
        TN = sum(confMat(:)) - (TP+FP+FN);

        if (TP+FN)>0
            class_accuracy(cIdx) = TP/(TP+FN);
        else
            class_accuracy(cIdx) = NaN;
        end
        if (TP+FP)>0
            class_precision(cIdx)= TP/(TP+FP);
        else
            class_precision(cIdx)= NaN;
        end
        if (TP+FN)>0
            class_recall(cIdx)   = TP/(TP+FN);
        else
            class_recall(cIdx)   = NaN;
        end
        if (TN+FP)>0
            class_specificity(cIdx)= TN/(TN+FP);
        else
            class_specificity(cIdx)= NaN;
        end
        prec = class_precision(cIdx);
        rec  = class_recall(cIdx);
        if ~(isnan(prec) || isnan(rec)) && (prec+rec)>0
            class_f1(cIdx) = 2*(prec*rec)/(prec+rec);
        else
            class_f1(cIdx) = NaN;
        end
    end
    overall_acc = sum(diag(confMat))/sum(confMat(:));
    macro_prec  = nanmean(class_precision);
    macro_rec   = nanmean(class_recall);
    macro_spec  = nanmean(class_specificity);
    macro_f1    = nanmean(class_f1);

    fprintf('Fold %d Classification => Overall=%.2f%%, MacroPrec=%.2f%%, MacroRec=%.2f%%, MacroSpec=%.2f%%, MacroF1=%.2f%%\n',...
        fold, overall_acc*100, macro_prec*100, macro_rec*100, macro_spec*100, macro_f1*100);
    fprintf('   Class 0 => Acc=%.2f%%, Prec=%.2f%%, Rec=%.2f%%, Spec=%.2f%%, F1=%.2f%%\n',...
        class_accuracy(1)*100, class_precision(1)*100, class_recall(1)*100, class_specificity(1)*100, class_f1(1)*100);
    fprintf('   Class 1 => Acc=%.2f%%, Prec=%.2f%%, Rec=%.2f%%, Spec=%.2f%%, F1=%.2f%%\n',...
        class_accuracy(2)*100, class_precision(2)*100, class_recall(2)*100, class_specificity(2)*100, class_f1(2)*100);

    rfMetrics = [rfMetrics; ...
        overall_acc, macro_prec, macro_rec, macro_spec, macro_f1, ...
        class_accuracy(1), class_precision(1), class_recall(1), class_specificity(1), class_f1(1), ...
        class_accuracy(2), class_precision(2), class_recall(2), class_specificity(2), class_f1(2)];

    %%% NEW %%% - Store this fold's testSet, predictions, final_probs, etc.
    allFolds_testSet{fold}      = testSet; 
    allFolds_predictedBIS{fold} = predictedBIS_test;

    % Probability from each ensemble
    all_probs = zeros(size(testDataClf,1), length(ensemble_models));
    for m = 1:length(ensemble_models)
        [~,scores] = predict(ensemble_models{m}, testDataClf);
        all_probs(:,m) = scores(:,2);
    end
    final_probs = mean(all_probs,2);
    allFolds_finalProbs{fold}      = final_probs;
    allFolds_ensemble_models{fold} = ensemble_models;

end % end for fold=1:k

