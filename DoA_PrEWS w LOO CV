function F1_macro = computeMultiClassF1(confMat)
    C = size(confMat,1);
    f1_vals = zeros(C,1);
    for c=1:C
        TP = confMat(c,c);
        FP = sum(confMat(:,c)) - TP;
        FN = sum(confMat(c,:)) - TP;
        if (TP+FP)==0 || (TP+FN)==0
            f1_vals(c) = NaN;
        else
            prec = TP/(TP+FP);
            rec  = TP/(TP+FN);
            f1_vals(c) = 2*(prec*rec)/(prec+rec);
        end
    end
    F1_macro = mean(f1_vals,'omitnan');
end

function [macroPrec, macroRec] = multiClassPrecRec(confMat)
    C = size(confMat,1);
    precVals = zeros(C,1);
    recVals  = zeros(C,1);
    for c = 1:C
        TP = confMat(c,c);
        FP = sum(confMat(:,c)) - TP;
        FN = sum(confMat(c,:)) - TP;
        if (TP+FP)>0
            precVals(c) = TP/(TP+FP);
        else
            precVals(c)=NaN;
        end
        if (TP+FN)>0
            recVals(c) = TP/(TP+FN);
        else
            recVals(c)=NaN;
        end
    end
    macroPrec = mean(precVals,'omitnan');
    macroRec  = mean(recVals,'omitnan');
end

function [Xshifted, BISshifted, subsetData] = shiftBISbyOffset(dataStruct, X, BIS, offset)
    n = size(X,1);
    if n~=length(BIS) || n~=length(dataStruct)
        error('shiftBISbyOffset: inconsistent row counts among X,BIS,dataStruct');
    end
    if n<=offset
        Xshifted   = [];
        BISshifted = [];
        subsetData = [];
        return;
    end
    idx_end = n-offset;
    Xshifted   = X(1:idx_end, :);
    BISshifted = BIS((1+offset):(idx_end+offset));
    subsetData = dataStruct(1:idx_end);
    for i=1:idx_end
        futureIdx = i+offset;
        subsetData(i).BISMedian_future = dataStruct(futureIdx).BISMedian;
        subsetData(i).Window_future    = dataStruct(futureIdx).Window;
    end
end

function [featMatrix, featNames] = createHistoricPredBISFeatures(dataSorted, predBIS_sorted, windowDuration)
    n = length(dataSorted);
    featMatrix = zeros(n, 12);
    featNames = { 'timeSinceFirstBelow60', 'timeSinceAnyBelow60', 'BIS_EMA', ...
                  'BISmean', 'BISmin', 'BISq1', 'BISmedian', 'BISq3', 'BISmax', ...
                  'prevPredBIS', 'deltaPredBIS', 'currPredBIS' };
    alpha = 0.3; 
    lastPatient = -1;
    firstBelow60HasOccurred = false;
    timeSinceFirst = 0;
    timeSinceAny   = 0;
    EMA_prev = 0;
    sumSoFar = 0;
    countSoFar = 0;
    bisHistory = [];
    prevBIS_val = NaN;

    for i = 1:n
        pID = dataSorted(i).Patient_ID;
        if pID~=lastPatient
            firstBelow60HasOccurred = false;
            timeSinceFirst = 0;
            timeSinceAny   = 0;
            EMA_prev       = predBIS_sorted(i);
            sumSoFar = 0;
            countSoFar= 0;
            bisHistory= [];
            prevBIS_val= predBIS_sorted(i);
            lastPatient= pID;
        end
        currBIS = predBIS_sorted(i);
        if ~firstBelow60HasOccurred
            if currBIS<60
                firstBelow60HasOccurred=true;
                timeSinceFirst=0;
            else
                timeSinceFirst= timeSinceFirst+1;
            end
        else
            timeSinceFirst= timeSinceFirst+1;
        end
        if currBIS<60
            timeSinceAny=0;
        else
            timeSinceAny= timeSinceAny+1;
        end
        if i==1 || pID~= dataSorted(i-1).Patient_ID
            EMA_curr= currBIS;
        else
            EMA_curr= alpha*currBIS + (1-alpha)*EMA_prev;
        end
        sumSoFar= sumSoFar+ currBIS;
        countSoFar= countSoFar+1;
        meanSoFar= sumSoFar/countSoFar;
        bisHistory(end+1)= currBIS; %#ok<AGROW>
        sortedHist= sort(bisHistory);
        minSoFar= sortedHist(1);
        maxSoFar= sortedHist(end);
        medianSoFar= median(sortedHist);
        q1SoFar= prctile(sortedHist,25);
        q3SoFar= prctile(sortedHist,75);
        prevBIS= prevBIS_val;
        deltaBIS= currBIS- prevBIS;

        featMatrix(i,1)= timeSinceFirst* windowDuration;
        featMatrix(i,2)= timeSinceAny * windowDuration;
        featMatrix(i,3)= EMA_curr;
        featMatrix(i,4)= meanSoFar;
        featMatrix(i,5)= minSoFar;
        featMatrix(i,6)= q1SoFar;
        featMatrix(i,7)= medianSoFar;
        featMatrix(i,8)= q3SoFar;
        featMatrix(i,9)= maxSoFar;
        featMatrix(i,10)= prevBIS;
        featMatrix(i,11)= deltaBIS;
        featMatrix(i,12)= currBIS;

        EMA_prev= EMA_curr;
        prevBIS_val= currBIS;
    end
end

function perf = huberperf(net, t, y, e, x, perfWeights)
%HUBERPERF Custom Huber loss performance function for a feedforward net.
%
%   net          - the network being trained
%   t, y, e      - target data, output data, and errors (t - y)
%   x            - input data
%   perfWeights  - weights (for weighting each sample)
%
% The net.performParam structure can contain:
%   net.performParam.delta (default ~1.0) 
%   which defines the "transition" threshold between L1 and L2.

% If net.performParam.delta is not set, use a default:
if ~isfield(net.performParam, 'delta')
    delta = 1.0;  % default
else
    delta = net.performParam.delta;
end

% Huber loss:
%     L(e) = 0.5 * e^2,           if |e| <= delta
%            delta*(|e| - 0.5*delta),  otherwise
%
% For vector data:
eabs = abs(e);

% Identify which elements are in quadratic region vs linear region
isQuad = (eabs <= delta);
isLin  = ~isQuad;

huberVals = zeros(size(e));

% Quadratic region (|e| <= delta)
huberVals(isQuad) = 0.5 * ( e(isQuad) ).^2;

% Linear region (|e| > delta)
huberVals(isLin)  = delta * ( eabs(isLin) - 0.5*delta );

% Weighted sum of losses
% perfWeights is typically a matrix the same size as e (or scalar)
if isempty(perfWeights)
    w = 1;  
else
    w = perfWeights;
end

% Weighted average
perf = sum(huberVals(:).* w(:)) / sum(w(:));
end

