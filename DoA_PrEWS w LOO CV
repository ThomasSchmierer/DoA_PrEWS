allFolds_futureLower   = cell(Kfolds,1);
allFolds_futureUpper   = cell(Kfolds,1);

%%% We can optionally track also the Xtest_BIS if needed, but typically storing testSet is enough.
for fold = 1:Kfolds
    % -------------------------------
    % Patient split (LOO vs K-fold)
    % -------------------------------
    if useLOO
        % LOO: hold out exactly one patient
        testPatients  = patientIDs(fold);
        trainPatients = patientIDs([1:fold-1, fold+1:end]);
    else
        % K-fold across patients (as before, but indexed on patients, not rows)
        testPatients  = patientIDs(idxPatients == fold);
        trainPatients = patientIDs(idxPatients ~= fold);
    end

    trainSet = all_data(ismember([all_data.Patient_ID], trainPatients));
    testSet  = all_data(ismember([all_data.Patient_ID], testPatients));

    [Xtrain_BIS, BIStrain, ~, ~] = prepareData(trainSet, num_features, num_bands);
    [Xtest_BIS,  BIStest,  ~, ~] = prepareData(testSet,  num_features, num_bands);

    [Xtrain_TTT, ~, TTTtrain, StateTrain] = prepareData(trainSet, num_features, num_bands);
    [Xtest_TTT,  ~, TTTtest,  StateTest]  = prepareData(testSet,  num_features, num_bands);

    %% 6A) BIS GPR
    BISmodel_fold = fitrgp( ...
        Xtrain_BIS(:, finalBISfeatures), ...
        BIStrain, ...
        'KernelFunction','matern52', ...
        'BasisFunction', bestBISParams.BasisFunction, ...
        'Sigma',         bestBISParams.Sigma, ...
        'Standardize',   true);

    predictedBIS_train = predict(BISmodel_fold, Xtrain_BIS(:, finalBISfeatures));
    predictedBIS_test  = predict(BISmodel_fold, Xtest_BIS(:, finalBISfeatures));

    mae_BIS  = mean(abs(predictedBIS_test - BIStest));
    rmse_BIS = sqrt(mean((predictedBIS_test - BIStest).^2));

    corr_BIS_train = corr(predictedBIS_train, BIStrain);
    corr_BIS_test  = corr(predictedBIS_test,  BIStest);

    correlation_BIS_metrics = [correlation_BIS_metrics; ...
                               corr_BIS_train, corr_BIS_test, rmse_BIS, mae_BIS];
    fprintf('Fold %d BIS => MAE=%.2f, RMSE=%.2f, CorrTrain=%.2f, CorrTest=%.2f\n',...
            fold, mae_BIS, rmse_BIS, corr_BIS_train, corr_BIS_test);
%%
% Bland-Altman plot (difference vs mean)
mean_BIS = mean([predictedBIS_test, BIStest], 2);
diff_BIS = predictedBIS_test - BIStest;

bias = mean(diff_BIS);
sd_diff = std(diff_BIS);
loa_upper = bias + 1.96 * sd_diff;
loa_lower = bias - 1.96 * sd_diff;

figure;
scatter(mean_BIS, diff_BIS, 25, 'filled', 'MarkerFaceAlpha', 0.6);
hold on;
yline(bias, 'k--', 'LineWidth', 1.5, 'Label', 'Mean Bias');
yline(loa_upper, 'r--', 'LineWidth', 1.5, 'Label', '+1.96 SD');
yline(loa_lower, 'r--', 'LineWidth', 1.5, 'Label', '-1.96 SD');

xlabel('Mean of Predicted and Actual BIS');
ylabel('Difference (Predicted - Actual)');
title('Bland-Altman Plot of BIS Prediction');
grid on;
hold off;


    %% New Feature Generation (historical predicted BIS)
    trainSet_sorted = sortrows(struct2table(trainSet), {'Patient_ID','Window'});
    testSet_sorted  = sortrows(struct2table(testSet),  {'Patient_ID','Window'});

    trainSet_sorted = table2struct(trainSet_sorted);
    testSet_sorted  = table2struct(testSet_sorted);

    [~, idxTrainMap] = sort([trainSet.Patient_ID]*1e8 + [trainSet.Window]); 
    predBIS_train_sorted = predictedBIS_train(idxTrainMap);

    [~, idxTestMap] = sort([testSet.Patient_ID]*1e8 + [testSet.Window]);
    predBIS_test_sorted = predictedBIS_test(idxTestMap);

    [featHistTrain, newFeatureNamesTrain] = ...
        createHistoricPredBISFeatures(trainSet_sorted, predBIS_train_sorted, window_duration);
    [featHistTest,  newFeatureNamesTest]  = ...
        createHistoricPredBISFeatures(testSet_sorted,  predBIS_test_sorted,  window_duration);

    nFeatRowsTrain = size(featHistTrain, 1);
    validTrain     = idxTrainMap <= nFeatRowsTrain;
    inverseIdxTrainMap = zeros(size(idxTrainMap));
    inverseIdxTrainMap(validTrain) = 1:sum(validTrain);
    featHistTrain_unsorted = featHistTrain(inverseIdxTrainMap(validTrain), :);

    nFeatRowsTest = size(featHistTest, 1);
    validTest     = idxTestMap <= nFeatRowsTest;
    inverseIdxTestMap = zeros(size(idxTestMap));
    inverseIdxTestMap(validTest) = 1:sum(validTest);
    featHistTest_unsorted = featHistTest(inverseIdxTestMap(validTest), :);

    Xtrain_BIS = Xtrain_BIS(validTrain, :);
    Xtest_BIS  = Xtest_BIS(validTest, :);

    Xtrain_BIS = [Xtrain_BIS, featHistTrain_unsorted];
    Xtest_BIS  = [Xtest_BIS,  featHistTest_unsorted];

    %% 6A.2) Region Classification
    Ytrain_region_str = strings(length(trainSet),1);
    for iR = 1:length(trainSet)
        Ytrain_region_str(iR) = trainSet(iR).region_label;
    end
    Ytrain_region_num = regionStr2Num(Ytrain_region_str);

    Ytest_region_str = strings(length(testSet),1);
    for iR = 1:length(testSet)
        Ytest_region_str(iR) = testSet(iR).region_label;
    end
    Ytest_region_num = regionStr2Num(Ytest_region_str);

    idx_c1 = find(Ytrain_region_num == 1);
    idx_c2 = find(Ytrain_region_num == 2);
    idx_c3 = find(Ytrain_region_num == 3);
    count1 = length(idx_c1);
    count2 = length(idx_c2);
    count3 = length(idx_c3);
    maxCount = max([count1, count2, count3]);

    Xtrain_region = Xtrain_BIS;
    Xc1 = Xtrain_region(idx_c1,:);
    short1 = maxCount - count1;
    if short1 > 0
        syn1 = smote(Xc1, short1, k_neighbors);
        Xc1_aug = [Xc1; syn1];
        Yc1_aug = [repmat(1, size(Xc1,1),1); repmat(1, size(syn1,1),1)];
    else
        Xc1_aug = Xc1;
        Yc1_aug = repmat(1, count1,1);
    end

    Xc2 = Xtrain_region(idx_c2,:);
    short2 = maxCount - count2;
    if short2 > 0
        syn2 = smote(Xc2, short2, k_neighbors);
        Xc2_aug = [Xc2; syn2];
        Yc2_aug = [repmat(2, size(Xc2,1),1); repmat(2, size(syn2,1),1)];
    else
        Xc2_aug = Xc2;
        Yc2_aug = repmat(2, count2,1);
    end

    Xc3 = Xtrain_region(idx_c3,:);
    short3 = maxCount - count3;
    if short3 > 0
        syn3 = smote(Xc3, short3, k_neighbors);
        Xc3_aug = [Xc3; syn3];
        Yc3_aug = [repmat(3, size(Xc3,1),1); repmat(3, size(syn3,1),1)];
    else
        Xc3_aug = Xc3;
        Yc3_aug = repmat(3, count3,1);
    end

    X_smote_train = [Xc1_aug; Xc2_aug; Xc3_aug];
    Y_smote_train = [Yc1_aug; Yc2_aug; Yc3_aug];
    idx_sh = randperm(size(X_smote_train,1));
    X_smote_train = X_smote_train(idx_sh,:);
    Y_smote_train = Y_smote_train(idx_sh);
    Y_smote_cat   = categorical(Y_smote_train, [1,2,3], {'Awake','Unconscious','Recovering'});

    extraFeatureIdx = (301:312)';  
    ClassificationBISfeatures = [finalBISfeatures; extraFeatureIdx];

    regionModel = fitcensemble(X_smote_train(:, ClassificationBISfeatures), ...
                               Y_smote_cat, 'Method','Bag', ...
                               'NumLearningCycles',100);
    Xtest_region = Xtest_BIS;
    Ytest_region_cat = categorical(Ytest_region_num, [1,2,3], ...
                                   {'Awake','Unconscious','Recovering'});
    pred_region = predict(regionModel, Xtest_region(:, ClassificationBISfeatures));
    confMat_region = confusionmat(Ytest_region_cat, pred_region, ...
                                  'Order',{'Awake','Unconscious','Recovering'});
    disp('Confusion Matrix (Region Classification):');
    disp(confMat_region);
    fold_regionF1 = computeMultiClassF1(confMat_region);
    fprintf('Fold %d => Region Macro-F1=%.2f%%\n', fold, fold_regionF1*100);

    overallAcc = sum(diag(confMat_region)) / sum(confMat_region(:));
    class_precision = zeros(1,3);
    class_recall    = zeros(1,3);
    class_specificity = zeros(1,3);
    class_f1        = zeros(1,3);
    class_accuracy  = zeros(1,3);
    for c = 1:3
        TP = confMat_region(c,c);
        FP = sum(confMat_region(:,c)) - TP;
        FN = sum(confMat_region(c,:)) - TP;
        TN = sum(confMat_region(:)) - (TP+FP+FN);
        if (TP + FN) > 0
            class_accuracy(c) = TP / (TP + FN);
        else
            class_accuracy(c) = NaN;
        end
        if (TP + FP) > 0
            class_precision(c) = TP / (TP + FP);
        else
            class_precision(c) = NaN;
        end
        if (TP + FN) > 0
            class_recall(c) = TP / (TP + FN);
        else
            class_recall(c) = NaN;
        end
        if (TN + FP) > 0
            class_specificity(c) = TN / (TN + FP);
        else
            class_specificity(c) = NaN;
        end
        if ~isnan(class_precision(c)) && ~isnan(class_recall(c)) ...
                && (class_precision(c) + class_recall(c))>0
            class_f1(c) = 2*(class_precision(c)*class_recall(c)) ...
                            /(class_precision(c)+class_recall(c));
        else
            class_f1(c) = NaN;
        end
    end
    macro_precision   = mean(class_precision,   'omitnan');
    macro_recall      = mean(class_recall,      'omitnan');
    macro_specificity = mean(class_specificity, 'omitnan');
    macro_f1          = mean(class_f1,          'omitnan');
    mean_class_acc    = mean(class_accuracy,    'omitnan');

    fprintf('Fold %d => OverallAcc=%.2f%%, MacroPrec=%.2f%%, MacroRec=%.2f%%, MacroSpec=%.2f%%, MacroF1=%.2f%%\n',...
         fold, 100*overallAcc, 100*macro_precision, 100*macro_recall, 100*macro_specificity, 100*macro_f1);
    fprintf(' Class1(Awake) => Acc=%.2f%%, Prec=%.2f%%, Rec=%.2f%%, Spec=%.2f%%, F1=%.2f%%\n',...
         100*class_accuracy(1), 100*class_precision(1), 100*class_recall(1), ...
         100*class_specificity(1), 100*class_f1(1));
    fprintf(' Class2(Uncns) => Acc=%.2f%%, Prec=%.2f%%, Rec=%.2f%%, Spec=%.2f%%, F1=%.2f%%\n',...
         100*class_accuracy(2), 100*class_precision(2), 100*class_recall(2), ...
         100*class_specificity(2), 100*class_f1(2));
    fprintf(' Class3(Recov) => Acc=%.2f%%, Prec=%.2f%%, Rec=%.2f%%, Spec=%.2f%%, F1=%.2f%%\n',...
         100*class_accuracy(3), 100*class_precision(3), 100*class_recall(3), ...
         100*class_specificity(3), 100*class_f1(3));
    fprintf(' Average Class Accuracy=%.2f%%\n', 100*mean_class_acc);

    region_confMat_sum = region_confMat_sum + confMat_region;
    region_metrics_all(fold,:) = [overallAcc, macro_precision, macro_recall, macro_f1];

    %% 6A.3) Future BIS
    [Xtrain_futureBIS, BIS_future_train, subsetDataTrain_future] = ...
        shiftBISbyOffset(trainSet, Xtrain_BIS, BIStrain, future_BIS_offset);
    [Xtest_futureBIS,  BIS_future_test,  subsetDataTest_future]  = ...
        shiftBISbyOffset(testSet,  Xtest_BIS,  BIStest,  future_BIS_offset);

    corr_future_train = NaN; corr_future_test = NaN;
    rmse_future_train = NaN; mae_future_train = NaN;
    rmse_future_test  = NaN; mae_future_test  = NaN;
    if ~isempty(Xtrain_futureBIS) && ~isempty(Xtest_futureBIS)
        extraFeatureIdx = (301:312)';  
        futureBISfeatures = [finalBISfeatures; extraFeatureIdx];

        futureBISmodel = fitrgp( ...
            Xtrain_futureBIS(:, futureBISfeatures), ...
            BIS_future_train, ...
            'KernelFunction','matern52', ...
            'BasisFunction', bestBISParams.BasisFunction, ...
            'Sigma',         bestBISParams.Sigma, ...
            'Standardize',   true, ...
            'FitMethod','sr', 'PredictMethod','sr');

        alpha = 0.10; % 90% CI
        [futureBIS_train_pred, ysd_train] = predict(futureBISmodel, Xtrain_futureBIS(:,futureBISfeatures));
        [futureBIS_test_pred,  ysd_test]  = predict(futureBISmodel, Xtest_futureBIS(:, futureBISfeatures));

        zVal = norminv((1 + 0.90)/2);  
        lower_train = futureBIS_train_pred - zVal*ysd_train;
        upper_train = futureBIS_train_pred + zVal*ysd_train;
        lower_test  = futureBIS_test_pred  - zVal*ysd_test;
        upper_test  = futureBIS_test_pred  + zVal*ysd_test;

        corr_future_train = corr(futureBIS_train_pred, BIS_future_train);
        corr_future_test  = corr(futureBIS_test_pred,  BIS_future_test);

        rmse_future_train = sqrt(mean((futureBIS_train_pred - BIS_future_train).^2));
        mae_future_train  = mean(abs(futureBIS_train_pred - BIS_future_train));
        rmse_future_test  = sqrt(mean((futureBIS_test_pred  - BIS_future_test).^2));
        mae_future_test   = mean(abs(futureBIS_test_pred  - BIS_future_test));

        coverageTrain = mean(BIS_future_train>=lower_train & BIS_future_train<=upper_train)*100;
        coverageTest  = mean(BIS_future_test >=lower_test  & BIS_future_test <=upper_test)*100;

        fprintf('Fold %d FutureBIS => CorrTrain=%.2f, CorrTest=%.2f (offset=%d)\n',...
            fold, corr_future_train, corr_future_test, future_BIS_offset);
        fprintf('                 => RMSE(Train)=%.2f, MAE(Train)=%.2f, RMSE(Test)=%.2f, MAE(Test)=%.2f\n',...
            rmse_future_train, mae_future_train, rmse_future_test, mae_future_test);
        fprintf('CoverageTrain=%.2f%%, CoverageTest=%.2f%% (90%% CI)\n', ...
