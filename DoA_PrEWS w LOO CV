        %%% Store into allFolds arrays for plotting later
        allFolds_futureTestSet{fold}  = subsetDataTest_future;
        allFolds_futurePredBIS{fold}  = futureBIS_test_pred;
        allFolds_futureLower{fold}    = lower_test;
        allFolds_futureUpper{fold}    = upper_test;
    end

    correlation_futureBIS = [correlation_futureBIS; ...
