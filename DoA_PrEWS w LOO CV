rfMetrics        = [];
clf2_confMat_sum = zeros(2,2);


% Per-fold stores for plotting
allFolds_testSet         = cell(Kfolds,1);
allFolds_predictedBIS    = cell(Kfolds,1);
allFolds_finalProbs      = cell(Kfolds,1);
allFolds_ensemble_models = cell(Kfolds,1);

