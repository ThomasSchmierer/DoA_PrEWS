patientIDs  = unique([all_data.Patient_ID]);
numPatients = numel(patientIDs);

%indices    = crossvalind('Kfold', patientIDs, k);

if useLOO
    Kfolds = numPatients;              % one fold per patient
else
    Kfolds = k;                         % keep your existing K value
    % Build folds across patients (not rows) to avoid patient leakage
    idxPatients = crossvalind('Kfold', numPatients, Kfolds);
end

% For BIS regression metrics
correlation_BIS_metrics = [];

% For region classification
region_confMat_sum = zeros(3,3);
region_metrics_all = zeros(Kfolds,4);

% For future BIS
correlation_futureBIS = [];

% For TTT model
correlation_metrics = [];

